generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  password      String
  role          UserRole      @default(CONSULTA)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  uploadedFiles CompanyFile[] @relation("UploadedBy")
  companies     UserCompany[]
}

model Company {
  id         String          @id @default(cuid())
  name       String
  cnpj       String?         @unique
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  balancetes BalanceteData[]
  files      CompanyFile[]
  users      UserCompany[]
  deParaMappings DeParaMapping[]
}

model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      UserRole @default(CONSULTA)
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

model StandardFile {
  id               String   @id @default(cuid())
  type             FileType @unique
  name             String
  description      String?
  cloudStoragePath String
  version          Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CompanyFile {
  id               String   @id @default(cuid())
  companyId        String
  type             FileType
  name             String
  cloudStoragePath String
  period           String?
  uploadedById     String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploadedBy       User     @relation("UploadedBy", fields: [uploadedById], references: [id])
}

model BalanceteData {
  id                 String   @id @default(cuid())
  companyId          String
  period             String
  accountNumber      String
  accountDescription String
  previousBalance    Decimal  @db.Decimal(18, 2)
  debit              Decimal  @db.Decimal(18, 2)
  credit             Decimal  @db.Decimal(18, 2)
  finalBalance       Decimal  @db.Decimal(18, 2)
  accountNature      String
  createdAt          DateTime @default(now())
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, period, accountNumber])
  @@index([companyId, period])
  @@index([accountNumber])
}

enum UserRole {
  ADMIN
  EDITOR
  CONSULTA
}

enum FileType {
  BP
  DRE
  DFC
  DMPL
  DE_PARA
  BALANCETE
}

model DeParaRow {
  id                String   @id @default(cuid())
  companyId          String
  contaBalancete     String
  descricaoBalancete String?
  padraoBP           String?
  padraoDRE          String?
  padraoDFC          String?
  padraoDMPL         String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([companyId, contaBalancete])
  @@index([companyId])
}

model BalanceteRow {
  id          String   @id @default(cuid())
  companyId    String
  periodo      String   // ex: "2025-12" ou "2025-12-31"
  conta        String
  descricao    String?
  saldoInicial Decimal? @db.Decimal(18,2)
  debito       Decimal? @db.Decimal(18,2)
  credito      Decimal? @db.Decimal(18,2)
  saldoFinal   Decimal? @db.Decimal(18,2)
  natureza     String?  // "D"/"C" se você tiver

  createdAt    DateTime @default(now())

  @@index([companyId, periodo])
}

model DeParaMapping {
  id                 String   @id @default(cuid())
  companyId           String
  contaFederacao      String
  descricaoFederacao  String?
  padraoBP            String?
  padraoDRE           String?
  padraoDFC           String?
  padraoDMPL          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, contaFederacao])
  @@index([companyId])
}